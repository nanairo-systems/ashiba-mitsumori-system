generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(uuid())
  authId        String         @unique
  name          String
  email         String         @unique
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  role          UserRole       @default(STAFF)
  auditLogs     AuditLog[]
  estimates     Estimate[]
  notifications Notification[]
  sendLogs      SendLog[]

  @@map("users")
}

model Company {
  id                 String    @id @default(uuid())
  name               String    @unique
  alias              String?
  phone              String?
  taxRate            Decimal   @default(0.10) @db.Decimal(4, 2)
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  furigana           String?
  paymentClosingDay  Int?
  paymentMonthOffset Int       @default(1)
  paymentNetDays     Int?
  paymentPayDay      Int?
  branches           Branch[]
  contacts           Contact[]

  @@map("companies")
}

model Branch {
  id        String    @id @default(uuid())
  companyId String
  name      String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  company   Company   @relation(fields: [companyId], references: [id])
  projects  Project[]

  @@unique([companyId, name])
  @@map("branches")
}

model Contact {
  id        String    @id @default(uuid())
  companyId String
  name      String
  phone     String
  email     String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  company   Company   @relation(fields: [companyId], references: [id])
  projects  Project[]
  sendLogs  SendLog[]

  @@map("contacts")
}

model Project {
  id          String     @id @default(uuid())
  shortId     String     @unique
  branchId    String
  contactId   String?
  name        String
  address     String?
  startDate   DateTime?
  endDate     DateTime?
  isArchived  Boolean    @default(false)
  archiveNote String?
  archivedAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  contracts   Contract[]
  estimates   Estimate[]
  branch      Branch     @relation(fields: [branchId], references: [id])
  contact     Contact?   @relation(fields: [contactId], references: [id])

  @@map("projects")
}

model Estimate {
  id                String             @id @default(uuid())
  projectId         String
  userId            String
  estimateNumber    String?
  revision          Int                @default(1)
  status            EstimateStatus     @default(DRAFT)
  addressType       AddressType        @default(COMPANY_CONTACT)
  validDays         Int                @default(30)
  note              String?
  discountAmount    Decimal?           @db.Decimal(12, 2)
  pdfUrl            String?
  keepPdf           Boolean            @default(false)
  confirmedAt       DateTime?
  sentAt            DateTime?
  followUpAt        DateTime?
  isArchived        Boolean            @default(false)
  archivedAt        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  estimateType      EstimateType       @default(INITIAL)
  title             String?
  contractEstimates ContractEstimate[]
  contract          Contract?
  sections          EstimateSection[]
  project           Project            @relation(fields: [projectId], references: [id])
  user              User               @relation(fields: [userId], references: [id])
  notifications     Notification[]
  sendLogs          SendLog[]

  @@map("estimates")
}

model EstimateSection {
  id         String          @id @default(uuid())
  estimateId String
  name       String
  sortOrder  Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  groups     EstimateGroup[]
  estimate   Estimate        @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@map("estimate_sections")
}

model EstimateGroup {
  id        String          @id @default(uuid())
  sectionId String
  name      String
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  section   EstimateSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  items     EstimateItem[]

  @@map("estimate_groups")
}

model EstimateItem {
  id        String        @id @default(uuid())
  groupId   String
  name      String
  quantity  Decimal       @db.Decimal(10, 2)
  unitId    String
  unitPrice Decimal       @db.Decimal(12, 2)
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  group     EstimateGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  unit      Unit          @relation(fields: [unitId], references: [id])

  @@map("estimate_items")
}

model Contract {
  id                    String                 @id @default(uuid())
  contractNumber        String?                @unique
  projectId             String
  estimateId            String?                @unique
  contractAmount        Decimal                @db.Decimal(12, 2)
  taxAmount             Decimal                @db.Decimal(12, 2)
  totalAmount           Decimal                @db.Decimal(12, 2)
  contractDate          DateTime
  startDate             DateTime?
  endDate               DateTime?
  paymentTerms          String?
  note                  String?
  status                ContractStatus         @default(CONTRACTED)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  adjustedAmount        Decimal?               @db.Decimal(12, 2)
  adjustedTotal         Decimal?               @db.Decimal(12, 2)
  discountAmount        Decimal                @default(0) @db.Decimal(12, 2)
  paymentType           PaymentType            @default(FULL)
  name                  String?
  schedules             ConstructionSchedule[]
  contractEstimates     ContractEstimate[]
  works                 ContractWork[]
  estimate              Estimate?              @relation(fields: [estimateId], references: [id])
  project               Project                @relation(fields: [projectId], references: [id])
  invoices              Invoice[]
  subcontractorPayments SubcontractorPayment[]

  @@map("contracts")
}

model ContractEstimate {
  id         String   @id @default(uuid())
  contractId String
  estimateId String
  createdAt  DateTime @default(now())
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  estimate   Estimate @relation(fields: [estimateId], references: [id])

  @@unique([contractId, estimateId])
  @@map("contract_estimates")
}

model Invoice {
  id            String        @id @default(uuid())
  contractId    String
  invoiceNumber String?       @unique
  invoiceType   InvoiceType   @default(FULL)
  amount        Decimal       @db.Decimal(12, 2)
  taxAmount     Decimal       @db.Decimal(12, 2)
  totalAmount   Decimal       @db.Decimal(12, 2)
  invoiceDate   DateTime
  dueDate       DateTime?
  status        InvoiceStatus @default(DRAFT)
  paidAmount    Decimal?      @db.Decimal(12, 2)
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  contract      Contract      @relation(fields: [contractId], references: [id], onDelete: Cascade)
  payments      Payment[]

  @@map("invoices")
}

model Payment {
  id             String   @id @default(uuid())
  invoiceId      String
  paymentDate    DateTime
  paymentAmount  Decimal  @db.Decimal(12, 2)
  transferFee    Decimal  @default(0) @db.Decimal(12, 2)
  discountAmount Decimal  @default(0) @db.Decimal(12, 2)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model ScheduleWorkTypeMaster {
  id         String   @id @default(uuid())
  code       String   @unique
  label      String
  shortLabel String
  colorIndex Int      @default(0)
  sortOrder  Int      @default(0)
  isDefault  Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("schedule_work_type_masters")
}

model ConstructionSchedule {
  id                String             @id @default(uuid())
  contractId        String
  workType          String
  plannedStartDate  DateTime?
  plannedEndDate    DateTime?
  actualStartDate   DateTime?
  actualEndDate     DateTime?
  workersCount      Int?
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  name              String?
  contract          Contract           @relation(fields: [contractId], references: [id], onDelete: Cascade)
  workerAssignments WorkerAssignment[]

  @@map("construction_schedules")
}

model Team {
  id                String             @id @default(uuid())
  name              String
  teamType          TeamType
  leaderId          String?
  subcontractorId   String?
  colorCode         String?
  sortOrder         Int                @default(0)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  workers           Worker?            @relation(fields: [leaderId], references: [id])
  subcontractors    Subcontractor?     @relation(fields: [subcontractorId], references: [id])
  workerAssignments WorkerAssignment[]

  @@map("teams")
}

model Worker {
  id                String             @id @default(uuid())
  name              String
  furigana          String?
  phone             String?
  email             String?
  workerType        WorkerType
  driverLicenseType DriverLicenseType  @default(NONE)
  defaultRole       WorkerRole         @default(WORKER)
  subcontractorId   String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  teams             Team[]
  workerAssignments WorkerAssignment[]
  subcontractors    Subcontractor?     @relation(fields: [subcontractorId], references: [id])

  @@map("workers")
}

model Vehicle {
  id                String             @id @default(uuid())
  name              String
  licensePlate      String
  vehicleType       String?
  capacity          String?
  inspectionDate    DateTime?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  notifications     Notification[]
  workerAssignments WorkerAssignment[]

  @@map("vehicles")
}

model WorkerAssignment {
  id            String               @id @default(uuid())
  scheduleId    String
  teamId        String
  workerId      String?
  vehicleId     String?
  assignedRole  WorkerRole
  assignedDate  DateTime?
  excludedDates DateTime[]           @default([])
  sortOrder     Int                  @default(0)
  note          String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  schedule      ConstructionSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  team          Team                 @relation(fields: [teamId], references: [id])
  vehicle       Vehicle?             @relation(fields: [vehicleId], references: [id])
  worker        Worker?              @relation(fields: [workerId], references: [id])

  @@map("worker_assignments")
}

model ContractWork {
  id               String         @id @default(uuid())
  contractId       String
  workType         WorkType       @default(INHOUSE)
  workerCount      Int?
  workDays         Int?
  subcontractorId  String?
  orderAmount      Decimal?       @db.Decimal(12, 2)
  orderTaxAmount   Decimal?       @db.Decimal(12, 2)
  orderTotalAmount Decimal?       @db.Decimal(12, 2)
  orderStatus      OrderStatus    @default(NOT_ORDERED)
  orderedAt        DateTime?
  note             String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  contract         Contract       @relation(fields: [contractId], references: [id], onDelete: Cascade)
  subcontractor    Subcontractor? @relation(fields: [subcontractorId], references: [id])

  @@map("contract_works")
}

model Subcontractor {
  id                    String                 @id @default(uuid())
  name                  String
  furigana              String?
  representative        String?
  address               String?
  phone                 String?
  email                 String?
  bankInfo              String?
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  contractWorks         ContractWork[]
  subcontractorPayments SubcontractorPayment[]
  teams                 Team[]
  workers               Worker[]

  @@map("subcontractors")
}

model SubcontractorPayment {
  id              String                     @id @default(uuid())
  contractId      String
  subcontractorId String
  orderAmount     Decimal                    @db.Decimal(12, 2)
  taxAmount       Decimal                    @db.Decimal(12, 2)
  totalAmount     Decimal                    @db.Decimal(12, 2)
  closingDate     DateTime?
  paymentDueDate  DateTime?
  paymentDate     DateTime?
  paymentAmount   Decimal?                   @db.Decimal(12, 2)
  status          SubcontractorPaymentStatus @default(PENDING)
  notes           String?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  contract        Contract                   @relation(fields: [contractId], references: [id], onDelete: Cascade)
  subcontractor   Subcontractor              @relation(fields: [subcontractorId], references: [id])

  @@map("subcontractor_payments")
}

model Template {
  id           String               @id @default(uuid())
  name         String
  description  String?
  isArchived   Boolean              @default(false)
  archivedAt   DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  estimateType TemplateEstimateType @default(BOTH)
  sections     TemplateSection[]
  templateTags TemplateTag[]

  @@map("templates")
}

model TemplateSection {
  id         String          @id @default(uuid())
  templateId String
  name       String
  sortOrder  Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  groups     TemplateGroup[]
  template   Template        @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("template_sections")
}

model TemplateGroup {
  id        String          @id @default(uuid())
  sectionId String
  name      String
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  section   TemplateSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  items     TemplateItem[]

  @@map("template_groups")
}

model TemplateItem {
  id        String        @id @default(uuid())
  groupId   String
  name      String
  quantity  Decimal?      @db.Decimal(10, 2)
  unitId    String
  unitPrice Decimal       @db.Decimal(12, 2)
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  group     TemplateGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  unit      Unit          @relation(fields: [unitId], references: [id])

  @@map("template_items")
}

model Unit {
  id            String         @id @default(uuid())
  name          String         @unique
  sortOrder     Int            @default(0)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  estimateItems EstimateItem[]
  templateItems TemplateItem[]

  @@map("units")
}

model Tag {
  id           String        @id @default(uuid())
  name         String        @unique
  isArchived   Boolean       @default(false)
  archivedAt   DateTime?
  createdAt    DateTime      @default(now())
  templateTags TemplateTag[]

  @@map("tags")
}

model TemplateTag {
  templateId String
  tagId      String
  createdAt  DateTime @default(now())
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@id([templateId, tagId])
  @@map("template_tags")
}

model SendLog {
  id         String   @id @default(uuid())
  estimateId String
  userId     String
  contactId  String?
  sentAt     DateTime @default(now())
  note       String?
  contact    Contact? @relation(fields: [contactId], references: [id])
  estimate   Estimate @relation(fields: [estimateId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@map("send_logs")
}

model Notification {
  id          String           @id @default(uuid())
  userId      String
  estimateId  String?
  type        NotificationType @default(FOLLOW_UP)
  message     String
  isRead      Boolean          @default(false)
  scheduledAt DateTime
  sentAt      DateTime?
  createdAt   DateTime         @default(now())
  vehicleId   String?
  estimate    Estimate?        @relation(fields: [estimateId], references: [id], onDelete: Restrict)
  user        User             @relation(fields: [userId], references: [id])
  vehicles    Vehicle?         @relation(fields: [vehicleId], references: [id])

  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  targetId  String?
  detail    Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model tel_call_history {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id   String?        @db.Uuid
  call_date     DateTime?      @default(now()) @db.Timestamptz(6)
  result        String?
  duration      String?
  operator      String?
  memo          String?
  question      String?
  answer        String?
  answered_by   String?
  answered_at   DateTime?      @db.Timestamptz(6)
  created_at    DateTime?      @default(now()) @db.Timestamptz(6)
  tel_customers tel_customers? @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([customer_id], map: "idx_tel_call_history_customer_id")
}

model tel_customers {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id      String?
  company_name     String?
  contact_name     String?
  department       String?
  phone            String?
  email            String?
  address          String?
  tags             String?
  call_count       Int?               @default(0)
  last_call_date   DateTime?          @db.Timestamptz(6)
  notes            String?
  archived         Boolean?           @default(false)
  archived_at      DateTime?          @db.Timestamptz(6)
  converted        Boolean?           @default(false)
  converted_at     DateTime?          @db.Timestamptz(6)
  company_id       String?
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?          @default(now()) @db.Timestamptz(6)
  tel_call_history tel_call_history[]

  @@index([archived], map: "idx_tel_customers_archived")
  @@index([business_id], map: "idx_tel_customers_business_id")
  @@index([converted], map: "idx_tel_customers_converted")
  @@index([updated_at(sort: Desc)], map: "idx_tel_customers_updated_at")
}

model tel_settings {
  key   String @id
  value Json?
}

enum UserRole {
  ADMIN
  STAFF
  DEVELOPER
}

enum EstimateStatus {
  DRAFT
  CONFIRMED
  SENT
  OLD
}

enum EstimateType {
  INITIAL
  ADDITIONAL
}

enum AddressType {
  COMPANY_CONTACT
  COMPANY_ONLY
}

enum InvoiceType {
  FULL
  ASSEMBLY
  DISASSEMBLY
  PROGRESS
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL_PAID
}

enum PaymentType {
  FULL
  TWO_PHASE
  PROGRESS
}

enum ContractStatus {
  CONTRACTED
  COMPLETED
  CANCELLED
  IN_PROGRESS
  BILLED
  PAID
  SCHEDULE_CREATED
}

enum WorkType {
  INHOUSE
  SUBCONTRACT
}

enum OrderStatus {
  NOT_ORDERED
  ORDERED
  COMPLETED
}

enum SubcontractorPaymentStatus {
  PENDING
  SCHEDULED
  PAID
}

enum TemplateEstimateType {
  INITIAL
  ADDITIONAL
  BOTH
}

enum NotificationType {
  FOLLOW_UP
  VEHICLE_INSPECTION
}

enum TeamType {
  INDIVIDUAL
  COMPANY
}

enum WorkerRole {
  FOREMAN
  WORKER
}

enum WorkerType {
  EMPLOYEE
  INDEPENDENT
  SUBCONTRACTOR
}

enum DriverLicenseType {
  NONE
  SMALL
  MEDIUM
  SEMI_LARGE
  LARGE
}
