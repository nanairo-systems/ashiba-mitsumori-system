generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────
// 自社ユーザー（Supabase Auth と連携）
// ─────────────────────────────────────────
model User {
  id        String   @id @default(uuid())
  authId    String   @unique // Supabase Auth の UUID
  name      String
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  estimates     Estimate[]
  sendLogs      SendLog[]
  notifications Notification[]
  auditLogs     AuditLog[]

  @@map("users")
}

// ─────────────────────────────────────────
// 会社マスター
// ─────────────────────────────────────────
model Company {
  id           String   @id @default(uuid())
  name         String   @unique // 重複防止
  alias        String?  // 別名（通称）
  phone        String?  // 代表電話番号（PDF に載せる）
  taxRate      Decimal  @default(0.10) @db.Decimal(4, 2) // 消費税率
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  branches     Branch[]
  contacts     Contact[]

  @@map("companies")
}

// ─────────────────────────────────────────
// 支店マスター
// ─────────────────────────────────────────
model Branch {
  id        String   @id @default(uuid())
  companyId String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company   @relation(fields: [companyId], references: [id])
  projects  Project[]

  @@unique([companyId, name])
  @@map("branches")
}

// ─────────────────────────────────────────
// 先方担当者マスター
// ─────────────────────────────────────────
model Contact {
  id        String   @id @default(uuid())
  companyId String
  name      String
  phone     String
  email     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company   @relation(fields: [companyId], references: [id])
  projects  Project[]
  sendLogs  SendLog[]

  @@map("contacts")
}

// ─────────────────────────────────────────
// 現場
// ─────────────────────────────────────────
model Project {
  id          String   @id @default(uuid())
  shortId     String   @unique // 表示用短ID（例: P-2402-001）
  branchId    String
  contactId   String?
  name        String   // 現場名（後から変更可）
  address     String?  // 任意
  startDate   DateTime? // 任意
  endDate     DateTime? // 任意
  isArchived  Boolean  @default(false) // 失注フラグ
  archiveNote String?  // 失注理由（任意）
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch    Branch     @relation(fields: [branchId], references: [id])
  contact   Contact?   @relation(fields: [contactId], references: [id])
  estimates Estimate[]

  @@map("projects")
}

// ─────────────────────────────────────────
// 見積
// ─────────────────────────────────────────
model Estimate {
  id             String         @id @default(uuid())
  projectId      String
  userId         String         // 担当者（作成者）
  estimateNumber String?        // 年月+連番（確定時に発行）例: 2402-003
  revision       Int            @default(1) // 版番号（-1, -2...）
  status         EstimateStatus @default(DRAFT)
  addressType    AddressType    @default(COMPANY_CONTACT) // 宛名形式
  validDays      Int            @default(30) // 有効期限（日数）
  note           String?        // 特記事項
  discountAmount Decimal?       @db.Decimal(12, 2) // 値引額
  pdfUrl         String?        // Supabase Storage の URL
  keepPdf        Boolean        @default(false) // 旧版PDFを残すか
  confirmedAt    DateTime?      // 確定日時
  sentAt         DateTime?      // 最終送付日時
  followUpAt     DateTime?      // 次回フォロー日時
  isArchived     Boolean        @default(false) // 下書き自動アーカイブ
  archivedAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  project   Project          @relation(fields: [projectId], references: [id])
  user      User             @relation(fields: [userId], references: [id])
  sections  EstimateSection[]
  sendLogs  SendLog[]
  notifications Notification[]

  @@map("estimates")
}

enum EstimateStatus {
  DRAFT     // 下書き
  CONFIRMED // 確定
  SENT      // 送付済
  OLD       // 旧版
}

enum AddressType {
  COMPANY_CONTACT // 会社名＋担当者名（デフォルト）
  COMPANY_ONLY    // 会社名のみ
}

// ─────────────────────────────────────────
// 見積 大項目（Section）
// ─────────────────────────────────────────
model EstimateSection {
  id         String   @id @default(uuid())
  estimateId String
  name       String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  estimate   Estimate         @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  groups     EstimateGroup[]

  @@map("estimate_sections")
}

// ─────────────────────────────────────────
// 見積 中項目（Group）
// ─────────────────────────────────────────
model EstimateGroup {
  id        String   @id @default(uuid())
  sectionId String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  section EstimateSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  items   EstimateItem[]

  @@map("estimate_groups")
}

// ─────────────────────────────────────────
// 見積 明細（Item）
// ─────────────────────────────────────────
model EstimateItem {
  id          String   @id @default(uuid())
  groupId     String
  name        String
  quantity    Decimal  @db.Decimal(10, 2)
  unitId      String
  unitPrice   Decimal  @db.Decimal(12, 2)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  group EstimateGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  unit  Unit          @relation(fields: [unitId], references: [id])

  @@map("estimate_items")
}

// ─────────────────────────────────────────
// テンプレ
// ─────────────────────────────────────────
model Template {
  id          String   @id @default(uuid())
  name        String
  description String?
  isArchived  Boolean  @default(false)
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sections     TemplateSection[]
  templateTags TemplateTag[]

  @@map("templates")
}

// ─────────────────────────────────────────
// テンプレ 大項目
// ─────────────────────────────────────────
model TemplateSection {
  id         String   @id @default(uuid())
  templateId String
  name       String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  template Template       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  groups   TemplateGroup[]

  @@map("template_sections")
}

// ─────────────────────────────────────────
// テンプレ 中項目
// ─────────────────────────────────────────
model TemplateGroup {
  id        String   @id @default(uuid())
  sectionId String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  section TemplateSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  items   TemplateItem[]

  @@map("template_groups")
}

// ─────────────────────────────────────────
// テンプレ 明細
// ─────────────────────────────────────────
model TemplateItem {
  id        String   @id @default(uuid())
  groupId   String
  name      String
  quantity  Decimal? @db.Decimal(10, 2) // テンプレ側も保持可（任意）
  unitId    String
  unitPrice Decimal  @db.Decimal(12, 2)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group TemplateGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  unit  Unit          @relation(fields: [unitId], references: [id])

  @@map("template_items")
}

// ─────────────────────────────────────────
// 単位マスター
// ─────────────────────────────────────────
model Unit {
  id        String   @id @default(uuid())
  name      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  estimateItems EstimateItem[]
  templateItems TemplateItem[]

  @@map("units")
}

// ─────────────────────────────────────────
// タグマスター
// ─────────────────────────────────────────
model Tag {
  id         String   @id @default(uuid())
  name       String   @unique
  isArchived Boolean  @default(false)
  archivedAt DateTime?
  createdAt  DateTime @default(now())

  templateTags TemplateTag[]

  @@map("tags")
}

// ─────────────────────────────────────────
// テンプレ×タグ（中間テーブル）
// ─────────────────────────────────────────
model TemplateTag {
  templateId String
  tagId      String
  createdAt  DateTime @default(now())

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([templateId, tagId])
  @@map("template_tags")
}

// ─────────────────────────────────────────
// 送付ログ
// ─────────────────────────────────────────
model SendLog {
  id         String   @id @default(uuid())
  estimateId String
  userId     String   // 送付者
  contactId  String   // 送付先担当者
  sentAt     DateTime @default(now())
  note       String?

  estimate Estimate @relation(fields: [estimateId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
  contact  Contact  @relation(fields: [contactId], references: [id])

  @@map("send_logs")
}

// ─────────────────────────────────────────
// システム内通知
// ─────────────────────────────────────────
model Notification {
  id         String           @id @default(uuid())
  userId     String
  estimateId String
  type       NotificationType @default(FOLLOW_UP)
  message    String
  isRead     Boolean          @default(false)
  scheduledAt DateTime        // 通知予定日時（フォロー当日17時）
  sentAt     DateTime?        // 実際に送信した日時
  createdAt  DateTime         @default(now())

  user     User     @relation(fields: [userId], references: [id])
  estimate Estimate @relation(fields: [estimateId], references: [id])

  @@map("notifications")
}

enum NotificationType {
  FOLLOW_UP // フォロー催促
}

// ─────────────────────────────────────────
// 操作ログ（監査用）
// ─────────────────────────────────────────
model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String   // 例: "estimate.confirm", "estimate.archive"
  targetId  String?  // 操作対象のID
  detail    Json?    // 詳細情報
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
