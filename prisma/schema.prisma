generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// 自社ユーザー（Supabase Auth と連携）
// ─────────────────────────────────────────
enum UserRole {
  ADMIN // 管理者：全機能 + ユーザー管理
  STAFF // スタッフ：見積・現場・マスター操作可、設定ページのみ不可
}

model User {
  id        String   @id @default(uuid())
  authId    String   @unique // Supabase Auth の UUID
  name      String
  email     String   @unique
  role      UserRole @default(STAFF) // 権限
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  estimates     Estimate[]
  sendLogs      SendLog[]
  notifications Notification[]
  auditLogs     AuditLog[]

  @@map("users")
}

// ─────────────────────────────────────────
// 会社マスター
// ─────────────────────────────────────────
model Company {
  id                   String   @id @default(uuid())
  name                 String   @unique // 重複防止
  furigana             String?  // ふりがな（ひらがな検索用）
  alias                String?  // 別名（通称）
  phone                String?  // 代表電話番号（PDF に載せる）
  taxRate              Decimal  @default(0.10) @db.Decimal(4, 2) // 消費税率
  // 支払条件設定（月次締め方式）
  paymentClosingDay    Int?     // 締め日: null=末日, 10=10日, 15=15日, 20=20日, 25=25日
  paymentMonthOffset   Int      @default(1) // 支払月: 1=翌月, 2=翌々月
  paymentPayDay        Int?     // 支払日: null=末日, 20=20日, 25=25日 など
  paymentNetDays       Int?     // 日数払い指定時 (例: 45日払い) ※設定時はこちらが優先
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  branches     Branch[]
  contacts     Contact[]

  @@map("companies")
}

// ─────────────────────────────────────────
// 支店マスター
// ─────────────────────────────────────────
model Branch {
  id        String   @id @default(uuid())
  companyId String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company   @relation(fields: [companyId], references: [id])
  projects  Project[]

  @@unique([companyId, name])
  @@map("branches")
}

// ─────────────────────────────────────────
// 先方担当者マスター
// ─────────────────────────────────────────
model Contact {
  id        String   @id @default(uuid())
  companyId String
  name      String
  phone     String
  email     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company   @relation(fields: [companyId], references: [id])
  projects  Project[]
  sendLogs  SendLog[]

  @@map("contacts")
}

// ─────────────────────────────────────────
// 現場
// ─────────────────────────────────────────
model Project {
  id          String   @id @default(uuid())
  shortId     String   @unique // 表示用短ID（例: P-2402-001）
  branchId    String
  contactId   String?
  name        String   // 現場名（後から変更可）
  address     String?  // 任意
  startDate   DateTime? // 任意
  endDate     DateTime? // 任意
  isArchived  Boolean  @default(false) // 失注フラグ
  archiveNote String?  // 失注理由（任意）
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch    Branch     @relation(fields: [branchId], references: [id])
  contact   Contact?   @relation(fields: [contactId], references: [id])
  estimates Estimate[]
  contracts Contract[]

  @@map("projects")
}

// ─────────────────────────────────────────
// 見積
// ─────────────────────────────────────────
model Estimate {
  id             String         @id @default(uuid())
  projectId      String
  userId         String         // 担当者（作成者）
  estimateNumber String?        // 年月+連番（確定時に発行）例: 2402-003
  revision       Int            @default(1) // 版番号（-1, -2...）
  title          String?        // 見積の名称（例: 「A棟工事」「追加 養生追加」）省略時は連番で表示
  estimateType   EstimateType   @default(INITIAL) // 当初見積 or 追加見積
  status         EstimateStatus @default(DRAFT)
  addressType    AddressType    @default(COMPANY_CONTACT) // 宛名形式
  validDays      Int            @default(30) // 有効期限（日数）
  note           String?        // 特記事項
  discountAmount Decimal?       @db.Decimal(12, 2) // 値引額
  pdfUrl         String?        // Supabase Storage の URL
  keepPdf        Boolean        @default(false) // 旧版PDFを残すか
  confirmedAt    DateTime?      // 確定日時
  sentAt         DateTime?      // 最終送付日時
  followUpAt     DateTime?      // 次回フォロー日時
  isArchived     Boolean        @default(false) // 下書き自動アーカイブ
  archivedAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  project   Project          @relation(fields: [projectId], references: [id])
  user      User             @relation(fields: [userId], references: [id])
  sections  EstimateSection[]
  sendLogs  SendLog[]
  notifications Notification[]
  contract  Contract?

  @@map("estimates")
}

enum EstimateStatus {
  DRAFT     // 下書き
  CONFIRMED // 確定
  SENT      // 送付済
  OLD       // 旧版
}

enum EstimateType {
  INITIAL    // 当初見積（初回・通常の見積）
  ADDITIONAL // 追加見積（工事開始後の追加・変更工事）
}

enum AddressType {
  COMPANY_CONTACT // 会社名＋担当者名（デフォルト）
  COMPANY_ONLY    // 会社名のみ
}

// ─────────────────────────────────────────
// 見積 大項目（Section）
// ─────────────────────────────────────────
model EstimateSection {
  id         String   @id @default(uuid())
  estimateId String
  name       String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  estimate   Estimate         @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  groups     EstimateGroup[]

  @@map("estimate_sections")
}

// ─────────────────────────────────────────
// 見積 中項目（Group）
// ─────────────────────────────────────────
model EstimateGroup {
  id        String   @id @default(uuid())
  sectionId String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  section EstimateSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  items   EstimateItem[]

  @@map("estimate_groups")
}

// ─────────────────────────────────────────
// 見積 明細（Item）
// ─────────────────────────────────────────
model EstimateItem {
  id          String   @id @default(uuid())
  groupId     String
  name        String
  quantity    Decimal  @db.Decimal(10, 2)
  unitId      String
  unitPrice   Decimal  @db.Decimal(12, 2)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  group EstimateGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  unit  Unit          @relation(fields: [unitId], references: [id])

  @@map("estimate_items")
}

// ─────────────────────────────────────────
// 契約
// ─────────────────────────────────────────
model Contract {
  id             String         @id @default(uuid())
  contractNumber String?        @unique // 例: C-2502-001（確定時に発行）
  projectId      String
  estimateId     String         @unique // 1見積につき1契約
  contractAmount Decimal        @db.Decimal(12, 2) // 税抜き金額
  taxAmount      Decimal        @db.Decimal(12, 2) // 消費税額
  totalAmount    Decimal        @db.Decimal(12, 2) // 税込合計
  contractDate   DateTime       // 契約日
  startDate      DateTime?      // 着工予定日
  endDate        DateTime?      // 完工予定日
  paymentTerms   String?        // 支払条件（テキスト / マスターから自動入力）
  note           String?        // 備考
  status         ContractStatus @default(CONTRACTED)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  project   Project  @relation(fields: [projectId], references: [id])
  estimate  Estimate @relation(fields: [estimateId], references: [id])
  works     ContractWork[]
  schedules ConstructionSchedule[]
  invoices  Invoice[]
  subcontractorPayments SubcontractorPayment[]

  @@map("contracts")
}

// ─────────────────────────────────────────
// 請求
// ─────────────────────────────────────────
enum InvoiceType {
  FULL         // 一括請求
  ASSEMBLY     // 組立分
  DISASSEMBLY  // 解体分
  PROGRESS     // 出来高
}

enum InvoiceStatus {
  DRAFT        // 下書き
  SENT         // 送付済
  PAID         // 入金済
  PARTIAL_PAID // 一部入金
}

model Invoice {
  id            String        @id @default(uuid())
  contractId    String
  invoiceNumber String?       @unique // 例: INV-2603-001
  invoiceType   InvoiceType   @default(FULL)
  amount        Decimal       @db.Decimal(12, 2) // 税抜
  taxAmount     Decimal       @db.Decimal(12, 2) // 消費税
  totalAmount   Decimal       @db.Decimal(12, 2) // 税込合計
  invoiceDate   DateTime      // 請求日
  dueDate       DateTime?     // 支払期日
  status        InvoiceStatus @default(DRAFT)
  paidAmount    Decimal?      @db.Decimal(12, 2) // 入金済み金額（一部入金用）
  paidAt        DateTime?     // 入金日
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@map("invoices")
}

// ─────────────────────────────────────────
// 入金
// ─────────────────────────────────────────
model Payment {
  id              String   @id @default(uuid())
  invoiceId       String
  paymentDate     DateTime // 入金日
  paymentAmount   Decimal  @db.Decimal(12, 2) // 入金額
  transferFee     Decimal  @default(0) @db.Decimal(12, 2) // 振込手数料
  discountAmount  Decimal  @default(0) @db.Decimal(12, 2) // 値引き額
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payments")
}

enum ContractStatus {
  CONTRACTED        // 契約済
  SCHEDULE_CREATED  // 工程作成済
  IN_PROGRESS       // 着工
  COMPLETED         // 完工
  BILLED            // 請求済
  PAID              // 入金済
  CANCELLED         // キャンセル
}

// ─────────────────────────────────────────
// 工期管理（工程スケジュール）
// ─────────────────────────────────────────
enum ScheduleWorkType {
  ASSEMBLY     // 組立
  DISASSEMBLY  // 解体
  REWORK       // 手直し・追加作業
}

model ConstructionSchedule {
  id               String            @id @default(uuid())
  contractId       String
  workType         ScheduleWorkType
  plannedStartDate DateTime?
  plannedEndDate   DateTime?
  actualStartDate  DateTime?
  actualEndDate    DateTime?
  workersCount     Int?
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("construction_schedules")
}

// ─────────────────────────────────────────
// 工事区分（自社 or 外注）
// ─────────────────────────────────────────
enum WorkType {
  INHOUSE       // 自社工事
  SUBCONTRACT   // 外注工事
}

enum OrderStatus {
  NOT_ORDERED   // 未発注
  ORDERED       // 発注済
  COMPLETED     // 完了
}

model ContractWork {
  id           String      @id @default(uuid())
  contractId   String
  workType     WorkType    @default(INHOUSE)

  // 自社工事の場合
  workerCount  Int?        // 工事人数
  workDays     Int?        // 工事日数

  // 外注工事の場合
  subcontractorId String?
  orderAmount     Decimal?  @db.Decimal(12, 2) // 発注金額（税抜）
  orderTaxAmount  Decimal?  @db.Decimal(12, 2) // 発注消費税
  orderTotalAmount Decimal? @db.Decimal(12, 2) // 発注合計（税込）
  orderStatus     OrderStatus @default(NOT_ORDERED)
  orderedAt       DateTime?

  note         String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  contract      Contract       @relation(fields: [contractId], references: [id], onDelete: Cascade)
  subcontractor Subcontractor? @relation(fields: [subcontractorId], references: [id])

  @@map("contract_works")
}

// ─────────────────────────────────────────
// 外注先（下請け業者）マスター
// ─────────────────────────────────────────
model Subcontractor {
  id           String   @id @default(uuid())
  name         String   // 会社名
  furigana     String?  // ふりがな
  representative String? // 代表者名
  address      String?  // 住所
  phone        String?  // 電話番号
  email        String?  // メール
  bankInfo     String?  // 振込先情報
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contractWorks ContractWork[]
  subcontractorPayments SubcontractorPayment[]

  @@map("subcontractors")
}

// ─────────────────────────────────────────
// 下請け支払い
// ─────────────────────────────────────────
enum SubcontractorPaymentStatus {
  PENDING    // 未処理
  SCHEDULED  // 支払予定
  PAID       // 支払済
}

model SubcontractorPayment {
  id               String                     @id @default(uuid())
  contractId       String
  subcontractorId  String
  orderAmount      Decimal                    @db.Decimal(12, 2) // 発注金額（税抜）
  taxAmount        Decimal                    @db.Decimal(12, 2) // 消費税
  totalAmount      Decimal                    @db.Decimal(12, 2) // 税込合計
  closingDate      DateTime?                  // 締め日
  paymentDueDate   DateTime?                  // 支払期日
  paymentDate      DateTime?                  // 実際の支払日
  paymentAmount    Decimal?                   @db.Decimal(12, 2) // 支払額
  status           SubcontractorPaymentStatus @default(PENDING)
  notes            String?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  contract      Contract      @relation(fields: [contractId], references: [id], onDelete: Cascade)
  subcontractor Subcontractor @relation(fields: [subcontractorId], references: [id])

  @@map("subcontractor_payments")
}

// ─────────────────────────────────────────
// テンプレ
// ─────────────────────────────────────────
model Template {
  id          String   @id @default(uuid())
  name        String
  description String?
  isArchived  Boolean  @default(false)
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sections     TemplateSection[]
  templateTags TemplateTag[]

  @@map("templates")
}

// ─────────────────────────────────────────
// テンプレ 大項目
// ─────────────────────────────────────────
model TemplateSection {
  id         String   @id @default(uuid())
  templateId String
  name       String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  template Template       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  groups   TemplateGroup[]

  @@map("template_sections")
}

// ─────────────────────────────────────────
// テンプレ 中項目
// ─────────────────────────────────────────
model TemplateGroup {
  id        String   @id @default(uuid())
  sectionId String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  section TemplateSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  items   TemplateItem[]

  @@map("template_groups")
}

// ─────────────────────────────────────────
// テンプレ 明細
// ─────────────────────────────────────────
model TemplateItem {
  id        String   @id @default(uuid())
  groupId   String
  name      String
  quantity  Decimal? @db.Decimal(10, 2) // テンプレ側も保持可（任意）
  unitId    String
  unitPrice Decimal  @db.Decimal(12, 2)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group TemplateGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  unit  Unit          @relation(fields: [unitId], references: [id])

  @@map("template_items")
}

// ─────────────────────────────────────────
// 単位マスター
// ─────────────────────────────────────────
model Unit {
  id        String   @id @default(uuid())
  name      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  estimateItems EstimateItem[]
  templateItems TemplateItem[]

  @@map("units")
}

// ─────────────────────────────────────────
// タグマスター
// ─────────────────────────────────────────
model Tag {
  id         String   @id @default(uuid())
  name       String   @unique
  isArchived Boolean  @default(false)
  archivedAt DateTime?
  createdAt  DateTime @default(now())

  templateTags TemplateTag[]

  @@map("tags")
}

// ─────────────────────────────────────────
// テンプレ×タグ（中間テーブル）
// ─────────────────────────────────────────
model TemplateTag {
  templateId String
  tagId      String
  createdAt  DateTime @default(now())

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([templateId, tagId])
  @@map("template_tags")
}

// ─────────────────────────────────────────
// 送付ログ
// ─────────────────────────────────────────
model SendLog {
  id         String   @id @default(uuid())
  estimateId String
  userId     String   // 送付者
  contactId  String?  // 送付先担当者（任意）
  sentAt     DateTime @default(now())
  note       String?

  estimate Estimate @relation(fields: [estimateId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
  contact  Contact? @relation(fields: [contactId], references: [id])

  @@map("send_logs")
}

// ─────────────────────────────────────────
// システム内通知
// ─────────────────────────────────────────
model Notification {
  id         String           @id @default(uuid())
  userId     String
  estimateId String
  type       NotificationType @default(FOLLOW_UP)
  message    String
  isRead     Boolean          @default(false)
  scheduledAt DateTime        // 通知予定日時（フォロー当日17時）
  sentAt     DateTime?        // 実際に送信した日時
  createdAt  DateTime         @default(now())

  user     User     @relation(fields: [userId], references: [id])
  estimate Estimate @relation(fields: [estimateId], references: [id])

  @@map("notifications")
}

enum NotificationType {
  FOLLOW_UP // フォロー催促
}

// ─────────────────────────────────────────
// 操作ログ（監査用）
// ─────────────────────────────────────────
model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String   // 例: "estimate.confirm", "estimate.archive"
  targetId  String?  // 操作対象のID
  detail    Json?    // 詳細情報
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
