generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(uuid())
  authId        String         @unique
  name          String
  email         String         @unique
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  role          UserRole       @default(STAFF)
  auditLogs     AuditLog[]
  estimates     Estimate[]
  notifications Notification[]
  sendLogs      SendLog[]

  @@map("users")
}

model Company {
  id                 String    @id @default(uuid())
  name               String    @unique
  alias              String?
  phone              String?
  taxRate            Decimal   @default(0.10) @db.Decimal(4, 2)
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  furigana           String?
  paymentClosingDay  Int?
  paymentMonthOffset Int       @default(1)
  paymentNetDays     Int?
  paymentPayDay      Int?
  branches           Branch[]
  contacts           Contact[]

  @@map("companies")
}

model Branch {
  id        String    @id @default(uuid())
  companyId String
  name      String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  company   Company   @relation(fields: [companyId], references: [id])
  projects  Project[]

  @@unique([companyId, name])
  @@map("branches")
}

model Contact {
  id        String    @id @default(uuid())
  companyId String
  name      String
  phone     String
  email     String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  company   Company   @relation(fields: [companyId], references: [id])
  projects  Project[]
  sendLogs  SendLog[]

  @@map("contacts")
}

model Project {
  id          String     @id @default(uuid())
  shortId     String     @unique
  branchId    String
  contactId   String?
  name        String
  address     String?
  startDate   DateTime?
  endDate     DateTime?
  isArchived  Boolean    @default(false)
  archiveNote String?
  archivedAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  contracts        Contract[]
  estimates        Estimate[]
  estimateBundles  EstimateBundle[]
  branch           Branch     @relation(fields: [branchId], references: [id])
  contact          Contact?   @relation(fields: [contactId], references: [id])

  @@map("projects")
}

model Estimate {
  id                String             @id @default(uuid())
  projectId         String
  userId            String
  estimateNumber    String?
  revision          Int                @default(1)
  status            EstimateStatus     @default(DRAFT)
  addressType       AddressType        @default(COMPANY_CONTACT)
  validDays         Int                @default(30)
  note              String?
  discountAmount    Decimal?           @db.Decimal(12, 2)
  pdfUrl            String?
  keepPdf           Boolean            @default(false)
  confirmedAt       DateTime?
  sentAt            DateTime?
  followUpAt        DateTime?
  isArchived        Boolean            @default(false)
  archivedAt        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  estimateType      EstimateType       @default(INITIAL)
  title             String?
  contractEstimates ContractEstimate[]
  contract          Contract?
  sections          EstimateSection[]
  project           Project            @relation(fields: [projectId], references: [id])
  user              User               @relation(fields: [userId], references: [id])
  notifications     Notification[]
  sendLogs          SendLog[]
  purchaseOrder     EstimatePurchaseOrder?
  bundleItems       EstimateBundleItem[]

  @@map("estimates")
}

model EstimateSection {
  id         String          @id @default(uuid())
  estimateId String
  name       String
  sortOrder  Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  groups     EstimateGroup[]
  estimate   Estimate        @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@map("estimate_sections")
}

model EstimateGroup {
  id        String          @id @default(uuid())
  sectionId String
  name      String
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  section   EstimateSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  items     EstimateItem[]

  @@map("estimate_groups")
}

model EstimateItem {
  id        String        @id @default(uuid())
  groupId   String
  name      String
  quantity  Decimal       @db.Decimal(10, 2)
  unitId    String
  unitPrice Decimal       @db.Decimal(12, 2)
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  group     EstimateGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  unit      Unit          @relation(fields: [unitId], references: [id])

  @@map("estimate_items")
}

model Contract {
  id                    String                 @id @default(uuid())
  contractNumber        String?                @unique
  projectId             String
  estimateId            String?                @unique
  contractAmount        Decimal                @db.Decimal(12, 2)
  taxAmount             Decimal                @db.Decimal(12, 2)
  totalAmount           Decimal                @db.Decimal(12, 2)
  contractDate          DateTime
  startDate             DateTime?
  endDate               DateTime?
  paymentTerms          String?
  note                  String?
  status                ContractStatus         @default(CONTRACTED)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  adjustedAmount        Decimal?               @db.Decimal(12, 2)
  adjustedTotal         Decimal?               @db.Decimal(12, 2)
  discountAmount        Decimal                @default(0) @db.Decimal(12, 2)
  paymentType           PaymentType            @default(FULL)
  name                  String?
  schedules             ConstructionSchedule[]
  contractEstimates     ContractEstimate[]
  works                 ContractWork[]
  estimate              Estimate?              @relation(fields: [estimateId], references: [id])
  project               Project                @relation(fields: [projectId], references: [id])
  invoices              Invoice[]
  subcontractorPayments SubcontractorPayment[]

  @@map("contracts")
}

model ContractEstimate {
  id         String   @id @default(uuid())
  contractId String
  estimateId String
  createdAt  DateTime @default(now())
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  estimate   Estimate @relation(fields: [estimateId], references: [id])

  @@unique([contractId, estimateId])
  @@map("contract_estimates")
}

model Invoice {
  id            String        @id @default(uuid())
  contractId    String
  invoiceNumber String?       @unique
  invoiceType   InvoiceType   @default(FULL)
  amount        Decimal       @db.Decimal(12, 2)
  taxAmount     Decimal       @db.Decimal(12, 2)
  totalAmount   Decimal       @db.Decimal(12, 2)
  invoiceDate   DateTime
  dueDate       DateTime?
  status        InvoiceStatus @default(DRAFT)
  paidAmount    Decimal?      @db.Decimal(12, 2)
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  contract      Contract      @relation(fields: [contractId], references: [id], onDelete: Cascade)
  payments      Payment[]

  @@map("invoices")
}

model Payment {
  id             String   @id @default(uuid())
  invoiceId      String
  paymentDate    DateTime
  paymentAmount  Decimal  @db.Decimal(12, 2)
  transferFee    Decimal  @default(0) @db.Decimal(12, 2)
  discountAmount Decimal  @default(0) @db.Decimal(12, 2)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model ScheduleWorkTypeMaster {
  id         String   @id @default(uuid())
  code       String   @unique
  label      String
  shortLabel String
  colorIndex Int      @default(0)
  sortOrder  Int      @default(0)
  isDefault  Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("schedule_work_type_masters")
}

model ConstructionSchedule {
  id                String             @id @default(uuid())
  contractId        String
  workType          String
  plannedStartDate  DateTime?
  plannedEndDate    DateTime?
  actualStartDate   DateTime?
  actualEndDate     DateTime?
  workersCount      Int?
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  name              String?
  contract          Contract           @relation(fields: [contractId], references: [id], onDelete: Cascade)
  workerAssignments WorkerAssignment[]

  @@map("construction_schedules")
}

model Team {
  id                String             @id @default(uuid())
  name              String
  teamType          TeamType
  leaderId          String?
  subcontractorId   String?
  colorCode         String?
  sortOrder         Int                @default(0)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  workers           Worker?            @relation(fields: [leaderId], references: [id])
  subcontractors    Subcontractor?     @relation(fields: [subcontractorId], references: [id])
  workerAssignments WorkerAssignment[]

  @@map("teams")
}

model Worker {
  id                String             @id @default(uuid())
  name              String
  furigana          String?
  phone             String?
  email             String?
  workerType        WorkerType
  driverLicenseType DriverLicenseType  @default(NONE)
  defaultRole       WorkerRole         @default(WORKER)
  subcontractorId   String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  teams             Team[]
  workerAssignments WorkerAssignment[]
  subcontractors    Subcontractor?     @relation(fields: [subcontractorId], references: [id])

  @@map("workers")
}

model Vehicle {
  id                String             @id @default(uuid())
  name              String
  licensePlate      String
  vehicleType       String?
  capacity          String?
  inspectionDate    DateTime?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  notifications     Notification[]
  workerAssignments WorkerAssignment[]

  @@map("vehicles")
}

model WorkerAssignment {
  id            String               @id @default(uuid())
  scheduleId    String
  teamId        String
  workerId      String?
  vehicleId     String?
  assignedRole  WorkerRole
  assignedDate  DateTime?
  excludedDates DateTime[]           @default([])
  sortOrder     Int                  @default(0)
  note          String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  schedule      ConstructionSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  team          Team                 @relation(fields: [teamId], references: [id])
  vehicle       Vehicle?             @relation(fields: [vehicleId], references: [id])
  worker        Worker?              @relation(fields: [workerId], references: [id])

  @@map("worker_assignments")
}

model ContractWork {
  id               String         @id @default(uuid())
  contractId       String
  workType         WorkType       @default(INHOUSE)
  workerCount      Int?
  workDays         Int?
  subcontractorId  String?
  orderAmount      Decimal?       @db.Decimal(12, 2)
  orderTaxAmount   Decimal?       @db.Decimal(12, 2)
  orderTotalAmount Decimal?       @db.Decimal(12, 2)
  orderStatus      OrderStatus    @default(NOT_ORDERED)
  orderedAt        DateTime?
  note             String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  contract         Contract       @relation(fields: [contractId], references: [id], onDelete: Cascade)
  subcontractor    Subcontractor? @relation(fields: [subcontractorId], references: [id])

  @@map("contract_works")
}

model Subcontractor {
  id                    String                 @id @default(uuid())
  name                  String
  furigana              String?
  representative        String?
  address               String?
  phone                 String?
  email                 String?
  bankInfo              String?
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  contractWorks            ContractWork[]
  subcontractorPayments    SubcontractorPayment[]
  teams                    Team[]
  workers                  Worker[]
  estimatePurchaseOrders   EstimatePurchaseOrder[]

  @@map("subcontractors")
}

model SubcontractorPayment {
  id              String                     @id @default(uuid())
  contractId      String
  subcontractorId String
  orderAmount     Decimal                    @db.Decimal(12, 2)
  taxAmount       Decimal                    @db.Decimal(12, 2)
  totalAmount     Decimal                    @db.Decimal(12, 2)
  closingDate     DateTime?
  paymentDueDate  DateTime?
  paymentDate     DateTime?
  paymentAmount   Decimal?                   @db.Decimal(12, 2)
  status          SubcontractorPaymentStatus @default(PENDING)
  notes           String?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  contract        Contract                   @relation(fields: [contractId], references: [id], onDelete: Cascade)
  subcontractor   Subcontractor              @relation(fields: [subcontractorId], references: [id])

  @@map("subcontractor_payments")
}

model Template {
  id           String               @id @default(uuid())
  name         String
  description  String?
  isArchived   Boolean              @default(false)
  archivedAt   DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  estimateType TemplateEstimateType @default(BOTH)
  sections     TemplateSection[]
  templateTags TemplateTag[]

  @@map("templates")
}

model TemplateSection {
  id         String          @id @default(uuid())
  templateId String
  name       String
  sortOrder  Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  groups     TemplateGroup[]
  template   Template        @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("template_sections")
}

model TemplateGroup {
  id        String          @id @default(uuid())
  sectionId String
  name      String
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  section   TemplateSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  items     TemplateItem[]

  @@map("template_groups")
}

model TemplateItem {
  id        String        @id @default(uuid())
  groupId   String
  name      String
  quantity  Decimal?      @db.Decimal(10, 2)
  unitId    String
  unitPrice Decimal       @db.Decimal(12, 2)
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  group     TemplateGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  unit      Unit          @relation(fields: [unitId], references: [id])

  @@map("template_items")
}

model Unit {
  id            String         @id @default(uuid())
  name          String         @unique
  sortOrder     Int            @default(0)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  estimateItems EstimateItem[]
  templateItems TemplateItem[]
  masterItems   MasterItem[]

  @@map("units")
}

model Tag {
  id           String        @id @default(uuid())
  name         String        @unique
  isArchived   Boolean       @default(false)
  archivedAt   DateTime?
  createdAt    DateTime      @default(now())
  templateTags TemplateTag[]

  @@map("tags")
}

model TemplateTag {
  templateId String
  tagId      String
  createdAt  DateTime @default(now())
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@id([templateId, tagId])
  @@map("template_tags")
}

model SendLog {
  id         String   @id @default(uuid())
  estimateId String
  userId     String
  contactId  String?
  sentAt     DateTime @default(now())
  note       String?
  contact    Contact? @relation(fields: [contactId], references: [id])
  estimate   Estimate @relation(fields: [estimateId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@map("send_logs")
}

model Notification {
  id          String           @id @default(uuid())
  userId      String
  estimateId  String?
  type        NotificationType @default(FOLLOW_UP)
  message     String
  isRead      Boolean          @default(false)
  scheduledAt DateTime
  sentAt      DateTime?
  createdAt   DateTime         @default(now())
  vehicleId   String?
  estimate    Estimate?        @relation(fields: [estimateId], references: [id], onDelete: Restrict)
  user        User             @relation(fields: [userId], references: [id])
  vehicles    Vehicle?         @relation(fields: [vehicleId], references: [id])

  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  targetId  String?
  detail    Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model tel_call_history {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id   String?        @db.Uuid
  call_date     DateTime?      @default(now()) @db.Timestamptz(6)
  result        String?
  duration      String?
  operator      String?
  memo          String?
  question      String?
  answer        String?
  answered_by   String?
  answered_at   DateTime?      @db.Timestamptz(6)
  created_at    DateTime?      @default(now()) @db.Timestamptz(6)
  tel_customers tel_customers? @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([customer_id], map: "idx_tel_call_history_customer_id")
}

model tel_customers {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id      String?
  company_name     String?
  contact_name     String?
  department       String?
  phone            String?
  email            String?
  address          String?
  tags             String?
  call_count       Int?               @default(0)
  last_call_date   DateTime?          @db.Timestamptz(6)
  notes            String?
  archived         Boolean?           @default(false)
  archived_at      DateTime?          @db.Timestamptz(6)
  converted        Boolean?           @default(false)
  converted_at     DateTime?          @db.Timestamptz(6)
  company_id       String?
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?          @default(now()) @db.Timestamptz(6)
  tel_call_history tel_call_history[]

  @@index([archived], map: "idx_tel_customers_archived")
  @@index([business_id], map: "idx_tel_customers_business_id")
  @@index([converted], map: "idx_tel_customers_converted")
  @@index([updated_at(sort: Desc)], map: "idx_tel_customers_updated_at")
}

model tel_settings {
  key   String @id
  value Json?
}

enum UserRole {
  ADMIN
  STAFF
  DEVELOPER
}

enum EstimateStatus {
  DRAFT
  CONFIRMED
  SENT
  OLD
}

enum EstimateType {
  INITIAL
  ADDITIONAL
}

enum AddressType {
  COMPANY_CONTACT
  COMPANY_ONLY
}

enum InvoiceType {
  FULL
  ASSEMBLY
  DISASSEMBLY
  PROGRESS
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL_PAID
}

enum PaymentType {
  FULL
  TWO_PHASE
  PROGRESS
}

enum ContractStatus {
  CONTRACTED
  COMPLETED
  CANCELLED
  IN_PROGRESS
  BILLED
  PAID
  SCHEDULE_CREATED
}

enum WorkType {
  INHOUSE
  SUBCONTRACT
}

enum OrderStatus {
  NOT_ORDERED
  ORDERED
  COMPLETED
}

enum EstimateOrderStatus {
  DRAFT
  ORDERED
  COMPLETED
}

model EstimatePurchaseOrder {
  id              String              @id @default(uuid())
  estimateId      String              @unique
  subcontractorId String
  orderAmount     Decimal             @db.Decimal(12, 2)
  taxRate         Int                 @default(10)
  note            String?
  status          EstimateOrderStatus @default(DRAFT)
  orderedAt       DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  estimate        Estimate            @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  subcontractor   Subcontractor       @relation(fields: [subcontractorId], references: [id])

  @@map("estimate_purchase_orders")
}

enum SubcontractorPaymentStatus {
  PENDING
  SCHEDULED
  PAID
}

enum TemplateEstimateType {
  INITIAL
  ADDITIONAL
  BOTH
}

enum NotificationType {
  FOLLOW_UP
  VEHICLE_INSPECTION
}

enum TeamType {
  INDIVIDUAL
  COMPANY
}

enum WorkerRole {
  FOREMAN
  WORKER
}

enum WorkerType {
  EMPLOYEE
  INDEPENDENT
  SUBCONTRACTOR
}

enum DriverLicenseType {
  NONE
  SMALL
  MEDIUM
  SEMI_LARGE
  LARGE
}

// ============================================
// 経理システム用モデル
// ============================================

enum ClosingType {
  MONTH_END
  DAY_15
}

enum SubInvoiceStatus {
  PENDING
  PAID
}

enum AccountType {
  ORDINARY
  CURRENT
}

model AccountingCompany {
  id          String       @id @default(uuid())
  name        String
  colorCode   String?
  sortOrder   Int          @default(0)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  departments Department[]
  vendors     Vendor[]
  subcontractorInvoices SubcontractorInvoice[]
}

model Department {
  id          String       @id @default(uuid())
  companyId   String
  name        String
  sortOrder   Int          @default(0)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  company     AccountingCompany @relation(fields: [companyId], references: [id])
  stores      Store[]
  vendorDepartments VendorDepartment[]
  subcontractorInvoices SubcontractorInvoice[]
  etcDrivers  EtcDriver[]
  employees   Employee[]
}

model Store {
  id           String      @id @default(uuid())
  departmentId String
  name         String
  sortOrder    Int         @default(0)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  department   Department  @relation(fields: [departmentId], references: [id])
  subcontractorInvoices SubcontractorInvoice[]
  etcDrivers   EtcDriver[]
  employees    Employee[]
}

model Vendor {
  id                          String       @id @default(uuid())
  companyId                   String
  name                        String
  furigana                    String?
  representativeName          String?
  phone                       String?
  email                       String?
  address                     String?
  bankName                    String?
  branchName                  String?
  accountType                 AccountType?
  accountNumber               String?
  accountHolder               String?
  closingType                 ClosingType  @default(MONTH_END)
  hasInvoiceRegistration      Boolean      @default(false)
  invoiceNumber               String?
  constructionInsuranceCompany String?
  constructionInsuranceNumber  String?
  constructionInsuranceExpiry  DateTime?
  vehicleInsuranceCompany      String?
  vehicleInsuranceNumber       String?
  vehicleInsuranceExpiry       DateTime?
  compulsoryInsuranceExpiry    DateTime?
  constructionLicenseNumber    String?
  constructionLicenseExpiry    DateTime?
  laborInsuranceNumber         String?
  employmentInsuranceNumber    String?
  hasForeignWorkers            Boolean      @default(false)
  foreignWorkerNote            String?
  startDate                    DateTime?
  rating                       String?
  antisocialCheckDone          Boolean      @default(false)
  isSuspended                  Boolean      @default(false)
  suspensionReason             String?
  emergencyContact             String?
  note                         String?
  isActive                     Boolean      @default(true)
  createdAt                    DateTime     @default(now())
  updatedAt                    DateTime     @updatedAt

  company              AccountingCompany    @relation(fields: [companyId], references: [id])
  departments          VendorDepartment[]
  vehicles             VendorVehicle[]
  employees            VendorEmployee[]
  subcontractorInvoices SubcontractorInvoice[]
}

model VendorDepartment {
  id           String     @id @default(uuid())
  vendorId     String
  departmentId String
  createdAt    DateTime   @default(now())

  vendor       Vendor     @relation(fields: [vendorId], references: [id])
  department   Department @relation(fields: [departmentId], references: [id])

  @@unique([vendorId, departmentId])
}

model VendorVehicle {
  id                   String    @id @default(uuid())
  vendorId             String
  plateNumber          String?
  vehicleType          String?
  compulsoryExpiry     DateTime?
  insuranceExpiry      DateTime?
  note                 String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  vendor               Vendor    @relation(fields: [vendorId], references: [id])
}

model VendorEmployee {
  id               String    @id @default(uuid())
  vendorId         String
  name             String
  birthDate        DateTime?
  position         String?
  qualifications   String?
  isForeignWorker  Boolean   @default(false)
  residenceStatus  String?
  note             String?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  vendor           Vendor    @relation(fields: [vendorId], references: [id])
}

model SubcontractorInvoice {
  id               String           @id @default(uuid())
  vendorId         String
  companyId        String
  departmentId     String
  storeId          String?
  billingYearMonth DateTime
  amount           Decimal          @db.Decimal(12, 2)
  closingType      ClosingType
  paymentDueDate   DateTime?
  paymentDate      DateTime?
  status           SubInvoiceStatus @default(PENDING)
  pdfUrl           String?
  note             String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  vendor           Vendor           @relation(fields: [vendorId], references: [id])
  company          AccountingCompany @relation(fields: [companyId], references: [id])
  department       Department       @relation(fields: [departmentId], references: [id])
  store            Store?           @relation(fields: [storeId], references: [id])
}

// ============================================
// 高速道路ICマスター（アラート用）
// ============================================

model HighwayIC {
  id         String   @id @default(uuid())
  name       String   @unique
  roadName   String?
  area       String   @default("normal")  // normal=通常エリア, outside=通常外
  note       String?
  createdAt  DateTime @default(now())
}

// ============================================
// 社員マスター
// ============================================

model Employee {
  id           String      @id @default(uuid())
  name         String
  departmentId String?
  storeId      String?
  phone        String?
  email        String?
  position     String?
  note         String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  department   Department? @relation(fields: [departmentId], references: [id])
  store        Store?      @relation(fields: [storeId], references: [id])
  etcDrivers   EtcDriver[]
}

// ============================================
// ETC 管理
// ============================================

model EtcVehicle {
  id           String      @id @default(uuid())
  plateNumber  String      @unique
  nickname     String?
  vehicleType  String?
  note         String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  cards        EtcCard[]
}

model EtcDriver {
  id           String      @id @default(uuid())
  name         String
  employeeId   String?
  departmentId String?
  storeId      String?
  note         String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  employee     Employee?   @relation(fields: [employeeId], references: [id])
  department   Department? @relation(fields: [departmentId], references: [id])
  store        Store?      @relation(fields: [storeId], references: [id])
  cards        EtcCard[]
  assignments  EtcDriverAssignment[]
}

model EtcDriverAssignment {
  id         String    @id @default(uuid())
  driverId   String
  cardId     String
  startDate  DateTime
  endDate    DateTime?
  note       String?
  createdAt  DateTime  @default(now())

  driver     EtcDriver @relation(fields: [driverId], references: [id])
  card       EtcCard   @relation(fields: [cardId], references: [id])

  @@index([cardId, startDate])
  @@index([driverId, startDate])
}

model EtcCard {
  id          String      @id @default(uuid())
  cardNumber  String      @unique
  vehicleId   String?
  driverId    String?
  note        String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  vehicle     EtcVehicle? @relation(fields: [vehicleId], references: [id])
  driver      EtcDriver?  @relation(fields: [driverId], references: [id])
  records     EtcRecord[]
  assignments EtcDriverAssignment[]
}

model EtcRecord {
  id             String    @id @default(uuid())
  cardId         String?
  cardNumber     String
  usageDate      DateTime
  dayOfWeek      String?
  usageType      String?
  destinationName String?
  plateNumber    String?
  amount         Decimal   @db.Decimal(10, 2)
  usageInfo      String?
  complianceInfo String?
  importedAt     DateTime  @default(now())
  yearMonth      String

  card           EtcCard?  @relation(fields: [cardId], references: [id])
}

// ============================================
// 項目マスタ
// ============================================

model ItemCategory {
  id        String       @id @default(uuid())
  name      String       @unique
  sortOrder Int          @default(0)
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  items     MasterItem[]

  @@map("item_categories")
}

model MasterItem {
  id         String       @id @default(uuid())
  categoryId String
  name       String
  unitId     String
  unitPrice  Decimal      @db.Decimal(12, 2)
  sortOrder  Int          @default(0)
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  category   ItemCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  unit       Unit         @relation(fields: [unitId], references: [id])

  @@unique([categoryId, name])
  @@map("master_items")
}

// ─── 見積セット（複数見積をまとめて提出）───

model EstimateBundle {
  id          String               @id @default(uuid())
  projectId   String
  bundleNumber String?             @unique
  title       String?
  note        String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  project     Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items       EstimateBundleItem[]

  @@map("estimate_bundles")
}

model EstimateBundleItem {
  id         String         @id @default(uuid())
  bundleId   String
  estimateId String
  sortOrder  Int            @default(0)
  createdAt  DateTime       @default(now())
  bundle     EstimateBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  estimate   Estimate       @relation(fields: [estimateId], references: [id])

  @@unique([bundleId, estimateId])
  @@map("estimate_bundle_items")
}
